{
  "server": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "auth": {
    "jwt_secret": "${SECRET_KEY}",
    "jwt_expiration": 1800,
    "jwt_algorithm": "HS256",
    "default_password": "${WEBSOCKET_PASSWORD}"
  },
  "providers": {
    "default": "deepseek",
    "deepseek": {
      "api_key": "${DEEPSEEK_API_KEY}",
      "base_url": "https://api.deepseek.com",
      "model": "deepseek-chat"
    },
    "openai": {
      "api_key": null,
      "base_url": null,
      "model": "gpt-4o"
    },
    "anthropic": {
      "api_key": null,
      "model": "claude-sonnet-4-20250514"
    },
    "ollama": {
      "base_url": "http://localhost:11434",
      "model": "llama3"
    }
  },
  "agent": {
    "system_prompt": "你是一个MCBE助手，请始终保持积极友好的态度。回答尽量保持一段话不要太长，适当添加换行符，尽量不要使用markdown",
    "enable_reasoning_output": true,
    "max_history_turns": 20,
    "agent_retries": 2,
    "worker_http_timeout": 60,
    "worker_poll_timeout": 1.0,
    "run_command_timeout": 10.0,
    "compression_enabled": true,
    "compression_trigger_ratio": 0.8,
    "compression_keep_recent_turns": 8,
    "compression_summary_max_chars": 2000,
    "compression_timeout": 30,
    "stream_sentence_mode": true,
    "llm_warmup_enabled": true,
    "mcwiki_base_url": "https://mcwiki.rice-awa.top",
    "dedup_external_messages": true,
    "tool_response_verbose": false,
    "request_limit": 8,
    "tool_calls_limit": 8,
    "input_tokens_limit": null,
    "output_tokens_limit": null,
    "total_tokens_limit": null,
    "run_timeout": 90.0,
    "max_tool_concurrency": 4,
    "context_output_reserve_tokens": 1024,
    "runtime_harness": {
      "enabled": true,
      "prompt_enabled": true,
      "schema_enabled": true,
      "audit_enabled": true,
      "audit_path": "logs/runtime_harness_tools.jsonl",
      "audit_max_records": 5000,
      "approval_ttl": 120.0,
      "max_batch_commands": 10,
      "hard_deny_tools": [],
      "hard_deny_command_roots": ["op", "deop", "stop", "whitelist", "permission", "wsserver"],
      "mcp_tool_allowlist": [],
      "tool_policy_version": "2026-07-21.1"
    }
  },
  "queue": {
    "max_size": 100,
    "llm_worker_count": 2
  },
  "websocket": {
    "ping_interval": 30,
    "ping_timeout": 15,
    "close_timeout": 15,
    "max_size": 10485760,
    "max_queue": 32
  },
  "minecraft": {
    "commands": {
      "#登录": "login",
      "AGENT 聊天": {
        "type": "chat",
        "aliases": ["AGENT chat", "AI 聊天", "AI chat"],
        "description": "与 AI 对话",
        "usage": "<内容>"
      },
      "AGENT 脚本": {
        "type": "chat_script",
        "aliases": ["AGENT script", "AI 脚本", "AI script"],
        "description": "使用脚本事件发送",
        "usage": "<内容>"
      },
      "AGENT 保存": {
        "type": "save",
        "aliases": ["AGENT save", "AI save"],
        "description": "保存当前对话历史",
        "usage": null
      },
      "AGENT 对话": {
        "type": "conversation",
        "aliases": ["AGENT conv", "AGENT conversation", "AI 对话", "AI conv"],
        "description": "管理对话",
        "usage": "<new/switch/clear/status/list/save/restore>"
      },
      "AGENT 上下文": {
        "type": "context",
        "aliases": ["AGENT context", "AI 上下文", "AI context"],
        "description": "管理上下文开关",
        "usage": "<启用/关闭/状态>"
      },
      "AGENT 模板": {
        "type": "template",
        "aliases": ["AGENT template", "AI 模板", "AI template"],
        "description": "切换提示词模板",
        "usage": "<模板名/list>"
      },
      "AGENT 设置": {
        "type": "setting",
        "aliases": ["AGENT setting", "AI 设置", "AI setting"],
        "description": "设置管理",
        "usage": "<变量/别名> <子命令>"
      },
      "AGENT MCP": {
        "type": "mcp",
        "aliases": ["AGENT mcp", "AI MCP", "AI mcp"],
        "description": "MCP 服务器管理",
        "usage": "<list/status/reload>"
      },
      "AGENT 广播": {
        "type": "ai_broadcast",
        "aliases": ["AGENT broadcast", "AI 广播", "AI broadcast"],
        "description": "AI 聊天广播策略管理",
        "usage": "<状态|关闭|全服 开启|关闭|玩家 <玩家名> 开启|关闭>"
      },
      "AGENT 工具审批": {
        "type": "tool_approval",
        "aliases": ["AGENT tool-approval", "AI 工具审批", "AI tool-approval"],
        "description": "审批高风险工具调用",
        "usage": "<approval_id> <允许|拒绝>"
      },
      "运行命令": {
        "type": "run_command",
        "aliases": ["runcmd", "cmd"],
        "description": "执行游戏命令",
        "usage": "<命令>"
      },
      "切换模型": {
        "type": "switch_model",
        "aliases": ["switch", "模型"],
        "description": "切换 LLM",
        "usage": "<provider>"
      },
      "帮助": {
        "type": "help",
        "aliases": ["help", "?"],
        "description": "显示此帮助",
        "usage": null
      }
    },
    "welcome_message_template": "-----------\n成功连接 MCBE AI Agent v{version}\n连接 ID: {connection_id}...\n当前模型: {provider}/{model}\n上下文: {context_status}\n-----------\n使用 \"{help_command}\" 查看可用命令",
    "context_enabled_text": "启用",
    "context_disabled_text": "关闭",
    "error_prefix": "❌ 错误: ",
    "info_prefix": "ℹ ",
    "success_prefix": "✅ ",
    "error_color": "§c",
    "info_color": "§b",
    "success_color": "§a"
  },
  "mcp": {
    "enabled": false,
    "servers": {}
  },
  "addon": {
    "protocol": {
      "bridge_message_id": "mcbeai:bridge_request",
      "bridge_prefix": "MCBEAI|RESP",
      "ui_chat_prefix": "MCBEAI|UI_CHAT",
      "bridge_tool_player_name": "MCBEAI_TOOL",
      "ai_resp_message_id": "mcbeai:ai_resp"
    }
  },
  "logging": {
    "level": "INFO",
    "enable_file_logging": true,
    "enable_ws_raw_log": false,
    "enable_llm_raw_log": false,
    "log_dir": "logs",
    "files": {
      "app": "app.log",
      "websocket_raw": "websocket.log",
      "llm_raw": "llm.log"
    },
    "rotation_when": "midnight",
    "rotation_interval": 1,
    "rotation_backup_count": 30
  },
  "storage": {
    "conversations_dir": "data/conversations",
    "tokens_file": "data/tokens.json"
  },
  "dev_mode": false,
  "flow_control": {
    "max_chunk_content_length": 400,
    "chunk_sentence_mode": true,
    "command_line_byte_budget": 461,
    "chunk_delays": {
      "tellraw": 0.05,
      "scriptevent": 0.05,
      "ai_resp": 0.15,
      "ai_resp_prelude": 0.5
    },
    "non_stream_batch_max_chars": 150,
    "non_stream_send_delay": 0.1
  },
  "model_metadata": {
    "enabled": true,
    "source_url": "https://models.dev/api.json",
    "refresh_on_startup": true,
    "timeout": 10,
    "cache_path": "data/model_metadata_cache.json"
  }
}
